    "vue-data-ui": "3.20.11",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "0.4.1",
    "@intlify/core-base": "11.3.0",
    "@npm/types": "2.1.0",
    "@playwright/test": "1.60.0",
    "@storybook-vue/nuxt": "catalog:storybook",
    "@storybook/addon-a11y": "catalog:storybook",
    "@storybook/addon-docs": "catalog:storybook",
    "@storybook/addon-themes": "catalog:storybook",
    "@types/node": "24.12.0",
    "@types/sanitize-html": "2.16.1",
    "@types/semver": "7.7.1",
    "@types/validate-npm-package-name": "4.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "@vue/test-utils": "2.4.6",
    "axe-core": "4.11.1",
    "changelogen": "0.6.2",
    "chromatic": "16.0.0",
    "devalue": "5.6.4",
    "eslint-plugin-regexp": "3.1.0",
    "fast-check": "4.6.0",
    "h3": "1.15.8",
    "h3-next": "npm:h3@2.0.1-rc.16",
    "knip": "6.14.2",
    "markdown-it-anchor": "9.2.0",
